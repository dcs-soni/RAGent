# ============================================================
# LangGraph Self-Corrective RAG Agent — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ------ Authentication ------
# Secret token used to authenticate API requests between frontend and backend.
# Generate a strong random value: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=change-me-to-a-strong-secret

# ------ LLM Provider ------
GOOGLE_API_KEY=your-google-api-key-here

# ------ Model Configuration ------
LLM_MODEL=gemini-2.0-flash
EMBEDDING_MODEL=models/text-embedding-004

# ------ Document Chunking ------
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ------ Retrieval ------
RETRIEVAL_K=4
RELEVANCE_THRESHOLD=0.7

# ------ Agent ------
MAX_RETRIES=3
HTTP_TIMEOUT_SECONDS=30
ENABLE_WEB_SEARCH=false
MAX_UPLOAD_SIZE_MB=25
MAX_FILENAME_LENGTH=128
MAX_UPLOAD_REQUEST_OVERHEAD_KB=256
UPLOAD_READ_CHUNK_SIZE_KB=256
MAX_CHAT_REQUEST_SIZE_KB=16
CHAT_RATE_LIMIT_REQUESTS=10
CHAT_RATE_LIMIT_WINDOW_SECONDS=60
DOCUMENT_WRITE_RATE_LIMIT_REQUESTS=10
DOCUMENT_WRITE_RATE_LIMIT_WINDOW_SECONDS=60
INGEST_RATE_LIMIT_REQUESTS=3
INGEST_RATE_LIMIT_WINDOW_SECONDS=300

# ------ Paths ------
DOCS_DIR=docs
CHROMA_DB_DIR=chroma_db

# ------ API ------
BACKEND_CORS_ORIGINS=["http://localhost:8501","http://127.0.0.1:8501"]

# ------ API Documentation (disabled by default in production) ------
# DOCS_ENABLED=false

# ------ Observability (LangSmith) ------
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=ragent_prod
LANGCHAIN_API_KEY=your-langsmith-api-key
